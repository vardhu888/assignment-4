from itertools import product

# Variables
regions = ["WA", "NT", "Q", "SA", "NSW", "V", "T"]

# Domains
colors = ["Red", "Green", "Blue"]

# Constraints (adjacency)
neighbors = {
    "WA": ["NT", "SA"],
    "NT": ["WA", "SA", "Q"],
    "SA": ["WA", "NT", "Q", "NSW", "V"],
    "Q": ["NT", "SA", "NSW"],
    "NSW": ["Q", "SA", "V"],
    "V": ["SA", "NSW"],
    "T": []
}

def is_valid(assignment):
    for region in assignment:
        for neighbor in neighbors[region]:
            if neighbor in assignment and assignment[region] == assignment[neighbor]:
                return False
    return True

def backtrack(assignment):
    if len(assignment) == len(regions):
        return assignment

    unassigned = [r for r in regions if r not in assignment][0]

    for color in colors:
        assignment[unassigned] = color
        if is_valid(assignment):
            result = backtrack(assignment)
            if result:
                return result
        del assignment[unassigned]

    return None

solution = backtrack({})

print("\nAustralia Map Coloring Solution:\n")
for region in regions:
    print(f"{region:5} → {solution[region]}")
